{
  "name": "fantasy-war-room",
  "version": "1.0.0",
  "description": "Fantasy football owner dashboard — draft war room, earnings tracking, free agent targets",
  "main": "index.html",
  "scripts": {
    "test": "node tests/run.js && npm run test:regression && npm run test:intelligence-surfaces && npm run test:draft-context && npm run test:draft-analyst-mock && npm run test:draft-trade-simulator && npm run test:draft-live-sync && npm run test:draft-live-decision && npm run test:ai && npm run test:ai-scale && npm run test:billing && npm run test:security && npm run test:bug-capture && npm run test:analytics && npm run test:tutorial && npm run test:rookies",
    "test:core": "node tests/run.js",
    "test:regression": "npm run build:preview && node tests/regression.js",
    "test:intelligence-surfaces": "node tests/intelligence-surface-contract.js",
    "test:draft-context": "node tests/draft-context-contract.js",
    "test:draft-analyst-mock": "node tests/draft-analyst-mock.js",
    "test:draft-trade-simulator": "node tests/draft-trade-simulator.js",
    "test:draft-live-sync": "node tests/draft-live-sync.js",
    "test:draft-live-decision": "node tests/draft-live-decision.js",
    "test:ai": "node tests/ai-routing.js",
    "test:ai-scale": "node scripts/ai-scale-load-model.cjs",
    "test:billing": "node tests/billing-schema.js",
    "test:security": "node tests/security-contract.js",
    "test:bug-capture": "node tests/bug-capture.js",
    "test:analytics": "node tests/analytics-report.js",
    "test:tutorial": "node tests/tutorial-contract.js",
    "test:rookies": "node tests/rookie-data.js",
    "test:browser": "npm run build:preview && node tests/browser-qa.js && node tests/launch-browser-qa.js",
    "test:launch-browser": "npm run build:preview && node tests/launch-browser-qa.js",
    "sync:shared": "node scripts/sync-reconai-shared.cjs",
    "verify:deploy": "node ../reconai/scripts/verify-deploy-readiness.cjs",
    "build:preview": "npm run sync:shared && node scripts/build-preview.cjs",
    "preview:prod": "npm run build:preview && node scripts/serve-static.cjs --port=3002",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:build:android": "npx cap build android",
    "prepare": "husky",
    "start": "npm run sync:shared && node scripts/serve-static.cjs --port=3001",
    "dev": "npm run sync:shared && node scripts/serve-static.cjs --port=3001"
  },
  "keywords": [
    "fantasy",
    "football",
    "dashboard"
  ],
  "author": "skjjcruz",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@babel/standalone": "^7.29.2",
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "eslint"
    ]
  }
}
